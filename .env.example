# MultiAgent-CodeForge 环境变量配置示例
# 复制此文件为 .env 并根据需要修改

# =============================================================================
# 应用配置
# =============================================================================

# 是否启用调试模式
DEBUG=false

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志文件路径（可选，不设置则只输出到控制台）
# LOG_FILE=logs/app.log

# =============================================================================
# Agent配置
# =============================================================================

# 最大并发任务数
MAX_CONCURRENT_TASKS=10

# 任务超时时间（秒）
TASK_TIMEOUT=300

# 重试次数
RETRY_ATTEMPTS=3

# 重试延迟（秒）
RETRY_DELAY=1.0

# =============================================================================
# 分析配置
# =============================================================================

# 默认工作流类型: full_analysis, quick_analysis, architecture_review, test_generation
DEFAULT_WORKFLOW=full_analysis

# 测试框架: pytest, unittest
TEST_FRAMEWORK=pytest

# =============================================================================
# 输出配置
# =============================================================================

# 输出目录
OUTPUT_DIRECTORY=output

# 临时文件目录
TEMP_DIRECTORY=temp
